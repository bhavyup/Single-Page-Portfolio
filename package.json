{
  "name": "single-page-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Portfolio with secure admin-backed dynamic content API",
  "main": "server/app.js",
  "scripts": {
    "dev": "node server/app.js",
    "start": "node server/app.js",
    "admin:hash": "node -e \"const bcrypt=require('bcryptjs');const pwd=process.argv[1];if(!pwd){console.error('Usage: npm run admin:hash -- <password>');process.exit(1);}console.log(bcrypt.hashSync(pwd,12));\"",
    "lint": "eslint \"server/**/*.js\" \"tests/**/*.js\"",
    "typecheck": "tsc -p jsconfig.node.json --noEmit",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "audit": "npm audit --audit-level=high",
    "check": "npm run lint && npm run typecheck && npm run test:coverage && npm run audit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "eslint": "^9.36.0",
    "jest": "^30.2.0",
    "supertest": "^7.1.4",
    "typescript": "^5.9.3"
  }
}
