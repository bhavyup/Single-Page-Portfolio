# Runtime
NODE_ENV=development
PORT=3000

# Admin credentials
ADMIN_USERNAME=admin
# Generate with: npm run admin:hash -- YourStrongPassword
ADMIN_PASSWORD_HASH=$2a$12$replace-with-bcrypt-hash

# Security secrets (use long random values)
JWT_SECRET=replace-with-long-random-jwt-secret
CSRF_SECRET=replace-with-long-random-csrf-secret
