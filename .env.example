# Runtime
NODE_ENV=development
PORT=3000

# Storage mode: 'file' (default) or 'database'
STORAGE_DRIVER=file

# Admin credentials
ADMIN_USERNAME=admin
# Generate with: npm run admin:hash -- YourStrongPassword
ADMIN_PASSWORD_HASH=$2a$12$replace-with-bcrypt-hash

# Security secrets (use long random values)
JWT_SECRET=replace-with-long-random-jwt-secret
CSRF_SECRET=replace-with-long-random-csrf-secret

# Database mode (MongoDB)
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB_NAME=portfolio

# Optional file path overrides (used by file mode and file seeding)
# CONTENT_FILE_PATH=server/data/content.json
# AUDIT_FILE_PATH=server/data/audit-log.json
# ASSET_UPLOAD_DIR=assets/uploads

# Assets storage (Vercel Blob)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# BLOB_ASSET_PREFIX=portfolio-assets/
